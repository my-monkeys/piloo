{
  "name": "piloo",
  "private": true,
  "version": "0.0.0",
  "description": "Piloo — carnet numérique de médicaments (monorepo)",
  "packageManager": "pnpm@10.26.1",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "eslint . && turbo run lint",
    "typecheck": "tsc --noEmit -p tsconfig.json && turbo run typecheck",
    "test": "vitest run && turbo run test",
    "openapi:generate": "turbo run openapi:generate openapi:generate-ts-client openapi:generate-dart-client",
    "openapi:generate-ts-client": "bash scripts/generate-ts-client.sh",
    "openapi:generate-dart-client": "bash scripts/generate-dart-client.sh",
    "openapi:generate-clients": "turbo run openapi:generate-ts-client openapi:generate-dart-client",
    "openapi:check": "turbo run openapi:generate && git diff --exit-code packages/api-contract/openapi.yaml",
    "db:generate": "pnpm --filter @piloo/db-schema generate",
    "db:migrate": "pnpm --filter @piloo/db-schema migrate",
    "clean": "turbo run clean && rm -rf node_modules .turbo"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jiti": "^2.6.1",
    "turbo": "^2.3.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
