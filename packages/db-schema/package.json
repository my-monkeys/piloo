{
  "name": "@piloo/db-schema",
  "private": true,
  "version": "0.0.0",
  "description": "Schéma Drizzle ORM (PostgreSQL) — source de vérité du modèle de données serveur",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./testing": "./src/testing.ts"
  },
  "scripts": {
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio",
    "seed": "node --experimental-strip-types --no-warnings=ExperimentalWarning src/seed.ts",
    "reset": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/reset.ts && pnpm migrate && pnpm seed",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
