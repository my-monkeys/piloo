{
  "name": "@piloo/api-contract",
  "private": true,
  "version": "0.0.0",
  "description": "Schémas Zod et document OpenAPI — source de vérité du contrat API",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas/*": "./src/schemas/*.ts"
  },
  "scripts": {
    "openapi:generate": "node --experimental-strip-types --no-warnings=ExperimentalWarning scripts/generate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "yaml": "^2.7.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
