{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "description": "Piloo — application web Next.js 15 (front + API)",
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "audit:logs": "node scripts/audit-logs.mjs",
    "bdpm:import": "node --experimental-strip-types scripts/import-bdpm.mjs",
    "bdpm:sqlite": "node --experimental-strip-types scripts/generate-bdpm-sqlite.mjs"
  },
  "dependencies": {
    "@piloo/api-client": "workspace:*",
    "@piloo/api-contract": "workspace:*",
    "@piloo/db-schema": "workspace:*",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.0.0",
    "better-auth": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.3",
    "lucide-react": "^1.16.0",
    "next": "^15.1.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.14",
    "tailwindcss": "^3.4.19",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
