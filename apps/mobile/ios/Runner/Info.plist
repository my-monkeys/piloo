<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Piloo</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>piloo</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<!-- Google Sign-In iOS (#65) — le SDK natif Google lit GIDClientID
	     directement dans Info.plist au moment de l'init. C'est le Client ID
	     iOS (PAS le Web client utilisé côté serveur). -->
	<key>GIDClientID</key>
	<string>325543119788-0r54du6ksvllbub2adruo63goqc6snus.apps.googleusercontent.com</string>
	<!-- URL Schemes : nécessaire pour Google Sign-In (#65). Le scheme est
	     le "reverse client ID" du Client iOS dans Google Cloud Console
	     (projet `piloo-495714`, client `Piloo iOS`). -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.325543119788-0r54du6ksvllbub2adruo63goqc6snus</string>
			</array>
		</dict>
	</array>
	<key>NSCameraUsageDescription</key>
	<string>Piloo utilise la caméra pour scanner le code DataMatrix de tes boîtes de médicaments et prendre en photo tes ordonnances pour les transcrire automatiquement.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Piloo accède à ta photothèque pour transcrire automatiquement une photo d'ordonnance que tu as déjà prise.</string>
	<key>NSContactsUsageDescription</key>
	<string>Piloo accède à tes contacts pour t'aider à inviter tes proches plus facilement. Aucun contact n'est envoyé à nos serveurs.</string>
	<!-- Background modes pour FCM (#122) :
	     - remote-notification : permet de recevoir des push silencieux
	       et de réveiller l'app pour le handler background.
	     - fetch : permet à iOS de réveiller l'app périodiquement pour
	       sync (utilisé indirectement par firebase_messaging). -->
	<key>UIBackgroundModes</key>
	<array>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
	<!-- Déclaration export crypto : Piloo n'utilise que la crypto fournie par
	     iOS (HTTPS via URLSession, Keychain via flutter_secure_storage), pas
	     d'algorithmes propriétaires ni standards en plus. Voir
	     https://developer.apple.com/documentation/security/complying_with_encryption_export_regulations
	     Évite la question "Missing Compliance" à chaque build TestFlight. -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>
	<!-- DEV ONLY : autorise HTTP vers IPs locales (192.168.x, etc.) pour
	     smoke-tester l'API Next.js (localhost ou LAN IP) sans HTTPS.
	     ATS bloque HTTP par défaut ; cette clé est plus chirurgicale que
	     NSAllowsArbitraryLoads (n'affecte QUE le réseau local).
	     À retirer avant soumission App Store. -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsLocalNetworking</key>
		<true/>
	</dict>
</dict>
</plist>
