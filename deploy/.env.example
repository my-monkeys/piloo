# deploy/.env — config du déploiement self-hosté cookie-server (#357).
# Copier en `deploy/.env` (gitignoré) et remplir. La liste EXHAUSTIVE des clés
# applicatives est dans le .env.example de la racine ; ci-dessous seulement ce
# qui CHANGE par rapport à la prod Vercel + les secrets DB locaux.

# --- Postgres local (conteneur piloo-db) ---
POSTGRES_USER=piloo
POSTGRES_DB=piloo
POSTGRES_PASSWORD=__CHANGE_ME__

# --- App : pointe sur la DB locale et le nouveau domaine public ---
# Hôte = nom du conteneur db sur le réseau `internal`.
DATABASE_URL=postgres://piloo:__CHANGE_ME__@piloo-db:5432/piloo
# Pas de pooler séparé en self-host : même URL (le compteur CU-hours n'existe plus).
DATABASE_POOL_URL=postgres://piloo:__CHANGE_ME__@piloo-db:5432/piloo
NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://piloo.my-monkey.fr
BETTER_AUTH_URL=https://piloo.my-monkey.fr

# --- Secrets RÉGÉNÉRABLES (Vercel ne les ré-expose pas via `env pull`,
#     ils sont "sensitive"/write-only). Génère-les : openssl rand -hex 32 ---
BETTER_AUTH_SECRET=
JWT_SECRET=
# Déclencheur de la route /api/cron/import-bdpm (openssl rand -hex 24)
CRON_SECRET=

# --- À fournir depuis les consoles fournisseurs (non récupérables via Vercel) ---
# Sans eux : login social / email / push / IA désactivés, mais le cœur marche.
# Google Cloud Console (OAuth)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_IOS_CLIENT_ID=
# Apple Developer (Sign in with Apple)
APPLE_CLIENT_ID=
APPLE_APP_BUNDLE_IDENTIFIER=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
# Brevo (email/SMS)
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=
# Firebase (push FCM) — JSON du service account, sur UNE ligne en quotes simples
FIREBASE_SERVICE_ACCOUNT_JSON=
# Google AI Studio (résumés notices BDPM)
GEMINI_API_KEY=
# Emails admin (séparés par virgule)
ADMIN_EMAILS=
