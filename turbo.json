{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local", ".env", ".env.example", "tsconfig.base.json"],
  "globalEnv": ["NODE_ENV", "CI", "VERCEL", "VERCEL_ENV"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "openapi:generate"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "build/**"]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": ["^build", "openapi:generate"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "openapi:generate"],
      "outputs": ["coverage/**"]
    },
    "openapi:generate": {
      "dependsOn": ["^openapi:generate"],
      "inputs": ["src/**/*.ts", "schemas/**/*.ts", "scripts/**/*.ts"],
      "outputs": ["openapi.yaml", "generated/**", "src/generated/**"]
    },
    "//#openapi:generate-ts-client": {
      "inputs": [
        "scripts/generate-openapi.ts",
        "scripts/generate-ts-client.sh",
        "packages/api-contract/openapi.yaml"
      ],
      "outputs": ["packages/api-client/src/generated/**"]
    },
    "//#openapi:generate-dart-client": {
      "inputs": [
        "scripts/generate-openapi.ts",
        "scripts/generate-dart-client.sh",
        "packages/api-contract/openapi.yaml"
      ],
      "outputs": ["apps/mobile/lib/gen/openapi/**"]
    },
    "//#openapi:generate-clients": {
      "dependsOn": ["//#openapi:generate-ts-client", "//#openapi:generate-dart-client"],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
