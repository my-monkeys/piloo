{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [
    "**/.env.*local",
    ".env",
    ".env.example",
    "tsconfig.base.json"
  ],
  "globalEnv": [
    "NODE_ENV",
    "CI",
    "VERCEL",
    "VERCEL_ENV"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^build",
        "openapi:generate",
        "//#openapi:generate-ts-client"
      ],
      "outputs": [
        ".next/**",
        "!.next/cache/**",
        "dist/**",
        "build/**"
      ]
    },
    "lint": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "^build",
        "openapi:generate",
        "//#openapi:generate-ts-client"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": [
        "^build",
        "openapi:generate",
        "//#openapi:generate-ts-client"
      ],
      "outputs": ["coverage/**"]
    },
    "openapi:generate": {
      "dependsOn": ["^openapi:generate"],
      "inputs": ["src/**/*.ts", "schemas/**/*.ts", "scripts/**/*.ts"],
      "outputs": [
        "openapi.yaml",
        "generated/**",
        "src/generated/**"
      ]
    },
    "//#openapi:generate-ts-client": {
      "dependsOn": ["@piloo/api-contract#openapi:generate"],
      "inputs": [
        "scripts/generate-openapi.ts",
        "scripts/generate-ts-client.sh",
        "packages/api-contract/openapi.yaml"
      ],
      "outputs": [
        "apps/web/lib/api/types.ts",
        "apps/web/lib/api/generated/**"
      ]
    },
    "//#openapi:generate-dart-client": {
      "dependsOn": ["@piloo/api-contract#openapi:generate"],
      "inputs": [
        "scripts/generate-openapi.ts",
        "scripts/generate-dart-client.sh",
        "packages/api-contract/openapi.yaml"
      ],
      "outputs": [
        "apps/mobile/lib/gen/openapi/**"
      ]
    },
    "//#openapi:generate-clients": {
      "dependsOn": [
        "//#openapi:generate-ts-client",
        "//#openapi:generate-dart-client"
      ],
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
