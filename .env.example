# =============================================================================
# Piloo — Variables d'environnement
# =============================================================================
# Copier ce fichier en `.env` (jamais commité) et remplir les valeurs.
# Ne jamais commiter de vrais secrets — `.env*` est dans `.gitignore`.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# URL publique de l'app web (utilisée pour les liens d'invitation, emails, CORS).
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Environnement courant : development | staging | production
NODE_ENV=development

# -----------------------------------------------------------------------------
# Base de données (PostgreSQL + Drizzle)
# -----------------------------------------------------------------------------
# URL Postgres principale (Neon / Railway / Supabase / local).
DATABASE_URL=postgres://user:password@localhost:5432/piloo
# URL avec pooling (optionnel, ex. Neon pgbouncer / Supabase pooler).
DATABASE_POOL_URL=

# -----------------------------------------------------------------------------
# Auth (Better Auth ou Clerk — à trancher en M1)
# -----------------------------------------------------------------------------
# Secret de signature des JWT mobiles + cookies session web (>= 32 caractères).
JWT_SECRET=changeme
# Durée de vie d'un access token (mobile). Format ms / string supporté par jose.
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
# Better Auth — secret + base URL
BETTER_AUTH_SECRET=changeme
BETTER_AUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# OAuth — Apple Sign-In (#64)
# -----------------------------------------------------------------------------
# Bundle ID iOS, sert aussi de `aud` au flow id-token natif.
# Pour le flow web il faudrait un Services ID séparé (pas couvert au M1).
APPLE_CLIENT_ID=fr.mymonkey.piloo
APPLE_APP_BUNDLE_IDENTIFIER=fr.mymonkey.piloo
APPLE_TEAM_ID=
APPLE_KEY_ID=
# Au choix : chemin vers le .p8 (dev) OU contenu PEM inline (prod/Vercel).
# Le .p8 ne doit JAMAIS être commité. Préférer le path en local.
APPLE_PRIVATE_KEY_PATH=
APPLE_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# OAuth — Google Sign-In (#65)
# -----------------------------------------------------------------------------
# Web client (utilisé côté serveur pour vérifier les id_token natifs ET pour
# le flow OAuth web). Les clients iOS/Android ont leurs propres client IDs
# (configurés directement dans les apps natives), mais le serveur n'a besoin
# que du Web client pour la vérification id_token.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Client ID iOS — utilisé en audience supplémentaire côté serveur car
# google_sign_in 7.x sur iOS émet l'id_token pour le client iOS même
# quand `serverClientId` est passé à initialize() (quirk du plugin).
# Optionnel : si vide, seul le Web client est accepté en audience.
GOOGLE_IOS_CLIENT_ID=

# -----------------------------------------------------------------------------
# Notifications — Email & SMS (Brevo)
# -----------------------------------------------------------------------------
BREVO_API_KEY=changeme
BREVO_SENDER_EMAIL=no-reply@piloo.app
BREVO_SENDER_NAME=Piloo

# -----------------------------------------------------------------------------
# Notifications — Push mobile (Firebase Cloud Messaging)
# -----------------------------------------------------------------------------
# Legacy server key (HTTP v1 préféré : utiliser FCM_SERVICE_ACCOUNT_JSON).
FCM_SERVER_KEY=changeme
# Service account JSON (HTTP v1) — chemin OU contenu JSON inline base64.
FCM_SERVICE_ACCOUNT_JSON=
FCM_PROJECT_ID=

# -----------------------------------------------------------------------------
# Stockage objets (S3 — photos d'ordonnances, exports)
# -----------------------------------------------------------------------------
S3_BUCKET=piloo-uploads
S3_REGION=eu-west-3
S3_ACCESS_KEY_ID=changeme
S3_SECRET_ACCESS_KEY=changeme
# Endpoint custom (MinIO local, Scaleway, Cloudflare R2…). Vide = AWS S3 standard.
S3_ENDPOINT=

# -----------------------------------------------------------------------------
# OCR / IA (vision pour ordonnances — phase ultérieure)
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Observabilité (optionnel)
# -----------------------------------------------------------------------------
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# -----------------------------------------------------------------------------
# BDPM (import base médicaments — côté job/cron serveur)
# -----------------------------------------------------------------------------
# URL de base data.gouv pour récupérer les TSV BDPM.
BDPM_SOURCE_URL=https://base-donnees-publique.medicaments.gouv.fr/telechargement.php

# -----------------------------------------------------------------------------
# Cron jobs (Vercel)
# -----------------------------------------------------------------------------
# Secret partagé entre Vercel Cron et l'endpoint /api/cron/*. Vercel envoie
# `Authorization: Bearer ${CRON_SECRET}` ; le handler doit le valider avant
# d'exécuter le job. À configurer en environnement Production uniquement
# (Vercel Cron ne tourne pas en preview). Générer 32+ bytes random.
CRON_SECRET=changeme
